%% Shared Infrastructure
Kafka[["Kafka"]]:::queue_color
CloudflareAI(["Cloudflare Workers AI"]):::external_service
Postgres[("PostgreSQL (Application DB)")]:::db_color
R2[("Cloudflare R2 (Object Storage)")]:::file_db_color
Milvus[("Milvus (Vector DB)")]:::vdb_color

%% Subdomains
DocumentService["Document Service (FastAPI)"]:::internal_python
DocumentWorker["Document Worker (Celery)"]:::internal_python
RabbitMQ[["RabbitMQ"]]:::queue_color

%% Luồng nội bộ của Document Subdomain
DocumentService -->|"Gửi tác vụ bất đồng bộ"| RabbitMQ
RabbitMQ -->|"Nhận tác vụ xử lý"| DocumentWorker

%% Event Broker
Kafka -.->|"Consume: payment_success \n(Cập nhật VIP subscription)"| DocumentService

%% Giao tiếp CSDL & Storage của Document Domain
DocumentService -->|"Đọc/Ghi dữ liệu người dùng"| Postgres
DocumentWorker -->|"Cập nhật trạng thái xử lý"| Postgres

DocumentService -->|"Tải lên file / Đọc Presigned URL"| R2
DocumentWorker -->|"Đọc file thô / Lưu Content & Summary"| R2

DocumentWorker -->|"Gửi Text / Nhận Summary"| CloudflareAI
DocumentWorker -->|"Đồng bộ Vector Embeddings"| Milvus
