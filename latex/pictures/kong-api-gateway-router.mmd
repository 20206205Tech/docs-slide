%% External Services (Màu xanh lá)
AuthService["Auth Service (Supabase)"]:::external_service
SettingService["Setting Service (Neon API)"]:::external_service

%% Internal NestJS Services (Màu đỏ)
PaymentService["Payment Service (Heroku)"]:::internal_nest
ConvService["Conversation Service"]:::internal_nest

%% Internal Python Services (Màu xanh dương Python)
PersonaService["Persona Service"]:::internal_python
ChatbotService["Chatbot + Voice Agent"]:::internal_python
DocumentService["Document (Docling)"]:::internal_python
VBPLService["VBPL Service"]:::internal_python
PhapDienService["PhapDien Service"]:::internal_python

%% --- LUỒNG ĐI (ROUTE MAPPING) ---
Client -->|Request| Kong

%% Route tới External Services
Kong -- "/supabase-auth-service/*" --> AuthService
Kong -- "/neon-setting-service/*" --> SettingService

%% Route tới NestJS Services
Kong -- "/code-payment-service/*" --> PaymentService
Kong -- "/code-conversation-service/*" --> ConvService

%% Route tới Python Services
Kong -- "/code-persona-service/*" --> PersonaService
Kong -- "/code-chatbot-service/*" --> ChatbotService
Kong -- "/code-document-service/*" --> DocumentService

%% Route tới các Service dữ liệu mới
Kong -- "/data-pipeline-vbplnew-service/*" --> VBPLService
Kong -- "/data-pipeline-phapdien-service/*" --> PhapDienService
