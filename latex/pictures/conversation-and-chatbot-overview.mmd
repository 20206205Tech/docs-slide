%% Khai báo node Queue & RTC chuẩn xác
Kafka[["Kafka"]]:::queue_color
RabbitMQ[["RabbitMQ"]]:::queue_color
LiveKit["LiveKit Server"]:::rtc

%% Các Service Python
PersonaService["Persona Service"]:::internal_python
ChatbotService["Chatbot Service"]:::internal_python

%% Service NestJS (Chỉ Conversation & Payment được dùng internal_nest)
ConvService["Conversation Service"]:::internal_nest

%% Các liên kết luồng dữ liệu
Kafka -->|"Event: payment_success"| ConvService
ConvService <-->|"gRPC (text)"| ChatbotService

ConvService -->|"Publish: chat_deletions & share_events"| RabbitMQ

ConvService -->|"Cấp Token JWT cho Client"| LiveKit
ChatbotService -->|"REST API cấu hình nhân vật"| PersonaService
ChatbotService <-->|"LiveKit Agent kết nối voice"| LiveKit

ChatbotService -->|"User Documents"| Milvus
ChatbotService -->|"VBPL"| Pinecone
ChatbotService -->|"Pháp Điển"| Qdrant

RabbitMQ -->|"Consume & Xử lý sự kiện"| ChatbotService
ChatbotService -->|"Tải lên/Xóa file chia sẻ"| R2Storage
ChatbotService --> ChatbotDB
ConvService --> ConvDB
